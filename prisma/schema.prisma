generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model badges {
  id            String   @id @db.VarChar(50)
  name          String   @db.VarChar(100)
  description   String   @db.Text
  icon_image    String?  @db.VarChar(255)
  criteria_type String?  @db.VarChar(50)
  created_at    DateTime @default(now()) @db.Timestamp(0)
}

model chapters {
  id          String @id @db.VarChar(50)
  story_id    String @db.VarChar(50)
  title       String @db.VarChar(255)
  order_index Int

  @@index([story_id], map: "story_id")
}

model page_quiz_options {
  id         String  @id @db.VarChar(50)
  page_id    String  @db.VarChar(50)
  text       String  @db.VarChar(255)
  feedback   String? @db.Text
  is_correct Boolean @default(false)

  @@index([page_id], map: "page_id")
}

model pages {
  id          String     @id @db.VarChar(50)
  chapter_id  String     @db.VarChar(50)
  type        pages_type
  title       String     @db.VarChar(255)
  content     String?    @db.Text
  image       String?    @db.VarChar(255)
  order_index Int

  @@index([chapter_id], map: "chapter_id")
}

model stories {
  id                String          @id @db.VarChar(50)
  number            String          @unique(map: "number") @db.VarChar(50)
  title             String          @db.VarChar(255)
  topic             String?         @db.VarChar(100)
  synopsis          String?         @db.Text
  status            stories_status? @default(draft)
  cover_image       String?         @db.VarChar(255)
  certificate_image String?         @db.VarChar(255)
  created_at        DateTime        @default(now()) @db.Timestamp(0)
  updated_at        DateTime        @default(now()) @db.Timestamp(0)
}

model test_items {
  id         String          @id @db.VarChar(50)
  story_id   String          @db.VarChar(50)
  type       test_items_type
  question   String          @db.Text
  created_at DateTime        @default(now()) @db.Timestamp(0)

  @@index([story_id], map: "story_id")
}

model test_options {
  id           String  @id @db.VarChar(50)
  test_item_id String  @db.VarChar(50)
  text         String  @db.VarChar(255)
  is_correct   Boolean @default(false)

  @@index([test_item_id], map: "test_item_id")
}

model user_badges {
  id        String   @id @db.VarChar(50)
  user_id   String   @db.VarChar(50)
  badge_id  String   @db.VarChar(50)
  earned_at DateTime @default(now()) @db.Timestamp(0)

  @@unique([user_id, badge_id], map: "user_id")
  @@index([badge_id], map: "badge_id")
}

model user_progress {
  id                    String                @id @db.VarChar(50)
  user_id               String                @db.VarChar(50)
  story_id              String                @db.VarChar(50)
  progress_percentage   Int?                  @default(0)
  pre_test_score        Int?
  post_test_score       Int?
  intermezzo_quiz_score Int?
  status                user_progress_status? @default(started)
  last_read_at          DateTime              @default(now()) @db.Timestamp(0)
  quiz_answers          String?               @db.LongText

  @@unique([user_id, story_id], map: "user_id")
  @@index([story_id], map: "story_id")
}

model users {
  id         String        @id @db.VarChar(50)
  name       String        @db.VarChar(100)
  email      String        @unique(map: "email") @db.VarChar(100)
  password   String        @db.VarChar(255)
  role       users_role?   @default(user)
  gender     users_gender?
  created_at DateTime      @default(now()) @db.Timestamp(0)
}

enum pages_type {
  story
  quiz
}

enum test_items_type {
  PRE_TEST
  POST_TEST
}

enum users_role {
  user
  admin
}

enum stories_status {
  draft
  published
}

enum user_progress_status {
  started
  completed
}

enum users_gender {
  L
  P
  EMPTY_ENUM_VALUE @map("")
}
